<Project Sdk="Aspire.AppHost.Sdk/13.4.6">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UserSecretsId>f8168281-f181-4ed5-9862-2faad8842402</UserSecretsId>
    <!-- Not part of src/Gateway.slnx on purpose — this is an optional local-dev orchestration layer, not
